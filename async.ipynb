   "source": [
    "import asyncio\n",
    "import string\n",
    "\n",
    "async def print_alphabet():\n",
    "    for letter in string.ascii_lowercase:\n",
    "        print(letter)\n",
    "        await asyncio.sleep(1)\n",
    "        \n",
    "async def main():\n",
    "    await print_alphabet()\n",
    "    \n",
    "# Run the async code\n",
    "await main()"
   ]
  }
